---
import { getCollection, render } from 'astro:content';
import Base from '../layouts/Base.astro';
import { execSync } from 'node:child_process';
import { resolve } from 'node:path';

export async function getStaticPaths() {
  // 注意：getStaticPaths 在独立作用域执行，只能访问 import，不能引用 frontmatter 顶层定义，
  // 所以 git 时间相关 helper 全部定义在函数内部。
  // 文章创建/更新时间取自 git 历史（首次提交 = 创建，最近提交 = 更新）——比文件 mtime 可靠
  // （OneDrive Files-On-Demand / sync-content 都会改写 mtime）。一次 git log 建全量映射。
  const REPO = resolve(process.cwd(), '..');
  const gitTimes = new Map<string, { created: number; updated: number }>();
  try {
    // core.quotePath=false：否则 git 会把中文路径做八进制转义并加引号，startsWith 失配。
    const out = execSync('git -c core.quotePath=false log --name-only --format=@@%ct -- knowledge_bases', {
      cwd: REPO, encoding: 'utf8', stdio: ['ignore', 'pipe', 'ignore'], maxBuffer: 256 * 1024 * 1024,
    });
    let ct = 0;
    for (const ln of out.split('\n')) {
      if (ln.startsWith('@@')) { ct = parseInt(ln.slice(2), 10) * 1000; continue; }
      const f = ln.trim();
      if (!f.endsWith('.md') || !f.startsWith('knowledge_bases/')) continue;
      const e = gitTimes.get(f);
      if (e) e.created = ct;          // git log 新→旧：越往后越老，持续覆盖 created
      else gitTimes.set(f, { updated: ct, created: ct });  // 首见 = 最新提交 = updated
    }
  } catch { /* 无 git → 时间留空 */ }
  // entry.id（content 路径，README 已转 index）→ 源文件 git 路径 knowledge_bases/<slug>/...md
  const gitPathOf = (id: string): string | null => {
    if (!id.startsWith('kb/')) return null;   // 外部挂载页的 git 历史不在本仓库，跳过
    let p = 'knowledge_bases/' + id.slice(3);
    if (p.endsWith('/index')) p = p.slice(0, -'/index'.length) + '/README.md';
    else p += '.md';
    return p;
  };

  const entries = await getCollection('docs');
  const seen = new Set<string>();
  const paths: any[] = [];
  for (const entry of entries) {
    // entry.id 不带 .md，是相对 src/content/docs/ 的路径。
    // index.md 已被 glob 转成 "/" slug，需要单独处理（很少见，KB 用 README.md）
    let slug = entry.id;
    // index → 目录 landing：slug 去掉末尾的 /index 或 index
    if (slug === 'index') slug = '';
    else if (slug.endsWith('/index')) slug = slug.slice(0, -'/index'.length);
    // 重复 slug 跳过（同目录下 README + 其他无效配对）
    if (seen.has(slug)) continue;
    seen.add(slug);
    const gp = gitPathOf(entry.id);
    const t = gp ? gitTimes.get(gp) : undefined;
    paths.push({
      params: { slug: slug || undefined },
      props: { entry, created: t?.created || 0, updated: t?.updated || 0 },
    });
  }
  return paths;
}

const { entry, created, updated } = Astro.props as { entry: any; created: number; updated: number };
const { Content } = await render(entry);

// 时间戳 → YYYY-MM-DD（绝对日期；ts=0 表示无 git 记录，留空不显示）
function fmtDate(ts: number): string {
  if (!ts) return '';
  const d = new Date(ts);
  const p = (n: number) => String(n).padStart(2, '0');
  return `${d.getFullYear()}-${p(d.getMonth() + 1)}-${p(d.getDate())}`;
}
const uDate = fmtDate(updated);
const cDate = fmtDate(created);  // 同一天的两次提交按日期相等 → 只显示更新于，不重复创建于

// 标题：frontmatter title → 正文首个 # 标题 → 文件名。
// frontmatter 在 sync-content.mjs 同步时已被 stripFrontmatter 剥掉，到不了 entry.data，
// 所以必须直接读正文 body 的 # 标题；否则目录 landing 页（entry.id 以 /index 结尾，
// 文件名退化成字面 "index"）的 <title> 会全部变成无区分度的 "index"。
const fileTitle = entry.id.split('/').pop()?.replace(/[-_]/g, ' ');
// 首个 ATX 标题（任意级别 # ~ ######）。很多 README 以 ## 开头，只认单 # 会漏判退化成 "index"。
const bodyTitle = ((entry as any).body || '').match(/^#{1,6}\s+(.+)$/m)?.[1]?.replace(/[#*`]/g, '').trim();
const title = (entry.data as any).title || bodyTitle || fileTitle;

// breadcrumb
const isIndex = entry.id === 'index' || entry.id.endsWith('/index');
const cleanedId = isIndex ? entry.id.replace(/\/?index$/, '') : entry.id;
const parts = cleanedId.split('/').filter((p) => p);
// 已存在的页面 URL 集合 —— crumb 只有命中真实页面才做链接（中间目录无 index 时
// 退化成纯文本），避免链到不存在的目录页 404。
const _allDocs = await getCollection('docs');
const existingUrls = new Set<string>();
for (const e of _allDocs) {
  let id = e.id;
  if (id === 'index') id = '';
  else if (id.endsWith('/index')) id = id.slice(0, -'/index'.length);
  existingUrls.add('/' + (id ? id + '/' : ''));
}
// 路由前缀段 'kb'（/kb/<slug>/... 里的 kb）不是可导航页面，从面包屑里跳过；
// 但 href 仍用完整路径构造（首个真实 crumb = KB slug → /kb/<slug>/）。
const skip = parts[0] === 'kb' ? 1 : 0;
// 路径段含字面 '%' 后跟非十六进制时 decodeURIComponent 会抛 URIError → 整页构建失败。
// 包一层回退，绝不让一个文件名拖垮整个 astro build。
const safeDecode = (s: string) => { try { return decodeURIComponent(s); } catch { return s; } };
const crumbs = parts.slice(0, -1).map((p, i) => {
  const href = '/' + parts.slice(0, i + 1).join('/') + '/';
  return { label: safeDecode(p), href, exists: existingUrls.has(href) };
}).slice(skip);
const lastCrumb = parts[parts.length - 1] || '总览';
---

<Base title={title}>
  <nav class="crumbs">
    <a href="/">首页</a>
    {crumbs.map((c) => (
      <>
        <span class="sep">›</span>
        {c.exists ? <a href={c.href}>{c.label}</a> : <span>{c.label}</span>}
      </>
    ))}
    {parts.length > 0 && (
      <>
        <span class="sep">›</span>
        {lastCrumb}
      </>
    )}
  </nav>
  {uDate && (
    <div class="doc-dates">
      <span>更新于 {uDate}</span>
      {cDate && cDate !== uDate ? (
        <>
          <span class="sep">·</span>
          <span>创建于 {cDate}</span>
        </>
      ) : null}
    </div>
  )}
  <article class="article">
    <Content />
  </article>
</Base>
