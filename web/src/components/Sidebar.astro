---
// Sidebar —— 对齐 docs/preview 的 Warm·M demo：统一扁平分组。
//
//   导航            首页
//   <当前 KB 名>     该 KB 的完整导航（来自其 _sidebar.md，剥掉「首页/切换知识库」样板）
//   其他知识库       其余 KB 的入口链接
//
//   首页（不在任何 KB 下）：导航 + 每个 KB 一组，列出该 KB 的顶层入口。
//
// 视觉样式全部来自 global.css（.nav-group / .nav-group-title / .sidebar a / a.sub）。
// 不再有折叠箭头、不再有「未分类（自动）」自动堆叠。

import SidebarItem from './SidebarItem.astro';
import type { Node } from './SidebarItem.astro';
import { getCollection } from 'astro:content';

// root _sidebar.md 可选（缺失 = KB 列表纯自动发现）；用 glob 容错，文件不存在也不报错。
const _rootSb = import.meta.glob('../../../_sidebar.md', { query: '?raw', import: 'default', eager: true }) as Record<string, string>;
const rootSidebarMd: string = (Object.values(_rootSb)[0] as string) || '';

// 各 KB 的 _sidebar.md（build-time，按 slug 索引）
const kbSidebarRaw = import.meta.glob('../../../knowledge_bases/*/_sidebar.md', {
  query: '?raw',
  import: 'default',
  eager: true,
}) as Record<string, string>;
const kbSidebars: Record<string, string> = {};
for (const [path, content] of Object.entries(kbSidebarRaw)) {
  const m = path.match(/\/knowledge_bases\/([^/]+)\/_sidebar\.md$/);
  if (m) kbSidebars[m[1]] = content;
}

function detectKbSlug(pathname: string): string | null {
  const m = pathname.match(/^\/kb\/([^/]+)/);
  if (m) return m[1];
  // 外部挂载页（/external-reports/... 等）：归到「在自己 _sidebar.md 里引用了它的 KB」名下，
  // 这样侧栏显示拥有它的 KB 的导航（外部条目在其中精排），而不是孤立成一个顶层组。
  const ext = pathname.match(/^\/([^/]+\/[^/]+)/);
  if (ext) {
    const needle = '/' + ext[1];
    for (const [s, md] of Object.entries(kbSidebars)) {
      if (md.includes(needle)) return s;
    }
  }
  return null;
}

function normalizeHref(href: string): string {
  if (!href) return href;
  if (href.startsWith('http')) return href;
  // 先拆掉 #锚点，重写完再接回。否则 foo.md#sec 的 ".md" 不在结尾，下面的规则漏判，
  // 会留下指向不存在的 .md 路由的死链（与 sync-content.mjs 对正文链接的处理保持一致）。
  const hashIdx = href.indexOf('#');
  const hash = hashIdx >= 0 ? href.slice(hashIdx) : '';
  let h = hashIdx >= 0 ? href.slice(0, hashIdx) : href;
  if (!h) return href; // 纯锚点（#sec）原样返回
  if (/(\/|^)README\.md$/i.test(h)) {
    h = h.replace(/(\/|^)README\.md$/i, (_, sep) => sep || '');
    if (!h) h = './'; // 裸 README.md（无路径分隔）→ 当前目录，不要变空串/根
    else if (!h.endsWith('/')) h += '/';
  } else if (/\.md$/i.test(h)) {
    h = h.replace(/\.md$/i, '/');
  }
  if (!h) h = '/';
  return h + hash;
}

function parseSidebar(text: string): Node[] {
  type StackEntry = { node: { children?: Node[] }; indent: number };
  const root: { children: Node[] } = { children: [] };
  const stack: StackEntry[] = [{ node: root, indent: -1 }];

  for (const rawLine of text.split('\n')) {
    if (!rawLine.trim()) continue;
    const m = rawLine.match(/^(\s*)-\s+(.+?)\s*$/);
    if (!m) continue;
    const indent = Math.floor(m[1].length / 2);
    const content = m[2];

    while (stack.length > 1 && stack[stack.length - 1].indent >= indent) stack.pop();
    const parent = stack[stack.length - 1].node;

    let node: Node;
    const bold = content.match(/^\*\*(.+)\*\*$/);
    if (bold) {
      node = { label: bold[1].trim(), bold: true, children: [] };
    } else {
      const link = content.match(/^\[(.+?)\]\((.+?)\)$/);
      if (link) {
        node = { label: link[1].trim(), href: normalizeHref(link[2].trim()) };
      } else {
        node = { label: content, children: [] };
      }
    }

    if (!parent.children) parent.children = [];
    parent.children.push(node);
    if (node.children) stack.push({ node, indent });
  }

  function clean(n: Node) {
    if (n.children) {
      if (n.children.length === 0) delete n.children;
      else n.children.forEach(clean);
    }
  }
  root.children.forEach(clean);
  return root.children;
}

// 从根 _sidebar.md 的「知识库列表」分组解析出 KB 列表（保序）。
function parseKbList(): { slug: string; label: string; href: string }[] {
  const tree = parseSidebar(rootSidebarMd);
  const group = tree.find((n) => n.children && /知识库列表|切换知识库/.test(n.label));
  const links = (group?.children || []).filter((n) => n.href);
  const out: { slug: string; label: string; href: string }[] = [];
  for (const n of links) {
    const m = (n.href || '').match(/^\/kb\/([^/]+)/);
    if (m) out.push({ slug: m[1], label: n.label, href: n.href! });
  }
  return out;
}

// 根 _sidebar.md 里「知识库列表」之外的自定义入口分组（个人工具 / 友链 / 外链 / 链接）：
// 原样渲染成侧栏分组，链接可站内可外链（normalizeHref 对 http(s) 透传，SidebarItem 外链开新标签）。
// 各库自管——根 _sidebar.md 不跨库同步，没有这类分组的库就不显示。
function parseLinkGroups(): { title: string; items: Node[] }[] {
  const tree = parseSidebar(rootSidebarMd);
  return tree
    .filter((n) => !!(n.children && n.children.length)
      && /工具|友链|外链|链接/.test(n.label)
      && !/知识库列表|切换知识库/.test(n.label))
    .map((n) => ({ title: n.label, items: (n.children || []).filter((c) => c.href || (c.children && c.children.length)) }));
}

// 剥掉 KB _sidebar.md 的样板（指向 / 的「KB 总览」链接 + 「切换知识库」分组），
// 并把唯一的「<KB> 专题」外壳分组解开一层，直接返回其内部导航。
function extractKbNav(text: string): Node[] {
  const tree = parseSidebar(text);
  const kept = tree.filter((n) => {
    if (n.href && normalizeHref(n.href) === '/') return false;
    if (n.children && /切换知识库|知识库列表/.test(n.label)) return false;
    return true;
  });
  if (kept.length === 1 && kept[0].children) return kept[0].children;
  return kept;
}

// ── EXTERNAL_MOUNTS 自动索引 ───────────────────────────────────
// getCollection 里所有「不在 kb/ 下」的条目 = EXTERNAL_MOUNTS（server/.env）同步进来的
// 外部目录（如 external-reports/...）。按路径自动建成可折叠侧栏树，无需手维护 _sidebar。
const allDocs = await getCollection('docs');
const docById = new Map(allDocs.map((e) => [e.id, e]));
function entryTitle(id: string): string {
  const e = docById.get(id);
  if (e) {
    if ((e.data as any)?.title) return (e.data as any).title;
    // 首个 ATX 标题（任意级别 # ~ ######）。很多 README 以 ## 开头，只认单 # 会漏判退化成文件名。
    const m = ((e as any).body || '').match(/^#{1,6}\s+(.+)$/m);
    if (m) return m[1].replace(/[#*`]/g, '').trim();
  }
  const seg = id.replace(/\/index$/, '').split('/').pop() || id;
  return seg.replace(/[-_]/g, ' ');
}
const extHref = (id: string) => '/' + id.replace(/\/index$/, '') + '/';
function buildExtTree(prefix: string): Node[] {
  const ids = allDocs
    .map((e) => e.id)
    .filter((id) => id === prefix || id.startsWith(prefix + '/'))
    .sort();
  const root: Node = { label: prefix, children: [] };
  for (const id of ids) {
    const rest = id.slice(prefix.length).replace(/^\//, '');
    const segs = rest ? rest.split('/') : [];
    let node: Node = root;
    for (const g of segs.slice(0, -1)) {
      node.children = node.children || [];
      let child = node.children.find((c) => c.children && (c as any)._seg === g);
      if (!child) {
        child = { label: g.replace(/[-_]/g, ' '), children: [] };
        (child as any)._seg = g;
        node.children.push(child);
      }
      node = child;
    }
    node.children = node.children || [];
    const last = segs[segs.length - 1] || 'index';
    if (last === 'index') node.children.unshift({ label: '总览', href: extHref(id) });
    else node.children.push({ label: entryTitle(id), href: extHref(id) });
  }
  return root.children || [];
}
const extPrefixes = Array.from(
  new Set(allDocs.map((e) => e.id.split('/')[0]).filter((p) => p && p !== 'kb'))
).sort();

// KB 自动发现：root _sidebar.md 的「知识库列表」提供顺序+标签（定制层），
// 未在其中列出的 slug 自动补在后面（标签取该 KB README 的 # 标题）。
function discoverKbList(): { slug: string; label: string; href: string }[] {
  const curated = parseKbList();
  const known = new Set(curated.map((k) => k.slug));
  const allSlugs = Array.from(
    new Set(allDocs.map((e) => (e.id.match(/^kb\/([^/]+)/) || [])[1]).filter(Boolean) as string[])
  ).sort();
  const extra = allSlugs
    .filter((s) => !known.has(s))
    .map((s) => ({ slug: s, label: entryTitle('kb/' + s + '/index') || s, href: '/kb/' + s + '/' }));
  return [...curated, ...extra];
}
// 某 KB 的导航：有 _sidebar.md → 按它精排；没有 → 按文件夹自动建树（fetch # 标题）。
function kbNavOf(s: string): Node[] {
  return kbSidebars[s] ? extractKbNav(kbSidebars[s]) : buildExtTree('kb/' + s);
}

// 自动补全外部新卡：KB 的 _sidebar.md 手列了一批外部条目（带 ⚠️ 标注/排序），但新建的
// 外部卡（如又加一个 per-dataset/NN-xxx.md）不会自动出现。这里把「已列外部条目所在目录」
// 下、_sidebar.md 还没列的同级页补成一组（用其 # 标题）。只补已 curate 目录的新同级文件
// （curatedDir 路径段≥2，避免把整棵外部树灌进来），既保留精排条目又让新卡自动现身。
function missingExtNodes(navNodes: Node[]): Node[] {
  const present = new Set<string>();
  const curatedDirs = new Set<string>();
  const norm = (h: string) => h.split('#')[0].replace(/\/+$/, '');
  const walk = (nodes: Node[]) => {
    for (const n of nodes) {
      if (n.href && !n.href.startsWith('http')) {
        const h = norm(n.href);
        present.add(h);
        if (!h.startsWith('/kb/')) {
          const dir = h.slice(0, h.lastIndexOf('/'));
          if (dir.split('/').filter(Boolean).length >= 2) curatedDirs.add(dir);
        }
      }
      if (n.children) walk(n.children);
    }
  };
  walk(navNodes);
  if (!curatedDirs.size) return [];
  const out: Node[] = [];
  for (const e of allDocs) {
    if (e.id.startsWith('kb/')) continue;          // 只看外部挂载
    const href = norm(extHref(e.id));
    const dir = href.slice(0, href.lastIndexOf('/'));
    if (curatedDirs.has(dir) && !present.has(href)) {
      out.push({ label: entryTitle(e.id), href: extHref(e.id) });
    }
  }
  out.sort((a, b) => ((a.href || '') < (b.href || '') ? -1 : 1));
  return out;
}

// Astro.url.pathname 对非 ASCII（中文文件名）一律 percent-encode，而 _sidebar.md 解析出的
// href / 自动建树的 href 都是原始中文串，直接字符串比较永不相等 → 中文页的侧栏当前页高亮 +
// 当前分支自动展开全部失效。解码回原始字符再比较；malformed %xx 回退原串避免 URIError。
const decodePath = (p: string) => { try { return decodeURIComponent(p); } catch { return p; } };
const currentPath = decodePath(Astro.url.pathname).replace(/\/$/, '') || '/';
const slug = detectKbSlug(currentPath);
const kbList = discoverKbList();
const labelOf = (s: string) => kbList.find((k) => k.slug === s)?.label || s;
const topSeg = currentPath.match(/^\/([^/]+)/)?.[1] || '';
const isHome = currentPath === '/';

type Group = { title: string; items: Node[] };
const groups: Group[] = [];

groups.push({ title: '导航', items: [{ label: '🏠 首页', href: '/' }] });

if (slug) {
  const nav = kbNavOf(slug);
  groups.push({ title: labelOf(slug), items: nav });
  // 该 KB 在 _sidebar.md 里引用的外部目录下、还没手列的新卡 → 自动补成一组。
  const autoExt = missingExtNodes(nav);
  if (autoExt.length) groups.push({ title: '外部资源 · 新增（自动）', items: autoExt });
  const others = kbList.filter((k) => k.slug !== slug).map((k) => ({ label: k.label, href: k.href }));
  if (others.length) groups.push({ title: '其他知识库', items: others });
} else if (isHome) {
  // 首页：每个 KB 一组，列出其顶层直达链接（不展开深层论文树）。
  for (const kb of kbList) {
    const top = kbNavOf(kb.slug).filter((n) => n.href && !n.children);
    groups.push({ title: kb.label, items: top.length ? top : [{ label: '总览', href: kb.href }] });
  }
} else {
  // 外部挂载页（或其它非 KB 页）：紧凑的 KB 入口，正文导航靠下面的外部挂载树。
  groups.push({ title: '知识库', items: kbList.map((k) => ({ label: k.label, href: k.href })) });
}

// 外部挂载自动索引：只在「非 KB 页」（首页 / 外部挂载页本身）显示。
// KB 页用各自 _sidebar.md（某些 KB 如 surgical 在里面手维护了外部引用 + ⚠️ 标注），
// 这里不再追加，避免同一批外部链接重复出现两次。
if (!slug) {
  for (const prefix of extPrefixes) {
    const items = buildExtTree(prefix);
    if (items.length) groups.push({ title: prefix, items });
  }
}
// 个人工具 / 友链等自定义入口：追加到侧栏末尾，所有页面可见，方便直接索引到外部工具。
for (const g of parseLinkGroups()) groups.push(g);
void topSeg;
---

<aside class="sidebar">
  <input class="search" type="search" placeholder="搜索全站..." aria-label="搜索" autocomplete="off" />
  <div class="search-results" role="listbox" aria-label="搜索结果" hidden></div>
  <nav>
    {groups.map((g) => (
      <div class="nav-group">
        <div class="nav-group-title">{g.title}</div>
        <ul class="nav-list">
          {g.items.map((node) => (
            <SidebarItem node={node} depth={0} currentPath={currentPath} />
          ))}
        </ul>
      </div>
    ))}
  </nav>
</aside>

<style is:global>
  .sidebar nav { padding-bottom: 24px; }
  .sidebar .nav-list { list-style: none; margin: 0; padding: 0; }
  .sidebar .nav-item { position: relative; }

  /* 可折叠的组小标题（如「论文卡片」「A. 分组」）——整行可点 */
  .sidebar .nav-subtitle {
    display: flex;
    align-items: center;
    gap: 5px;
    width: 100%;
    box-sizing: border-box;
    background: none;
    border: 0;
    cursor: pointer;
    text-align: left;
    font: inherit;
    font-size: 12.5px;
    font-weight: 600;
    color: var(--fg-muted);
    padding: 5px 10px;
    border-radius: var(--r-sm);
    transition: color 0.12s, background 0.12s;
  }
  .sidebar .nav-subtitle:hover { color: var(--fg); background: var(--bg-soft); }
  .sidebar .nav-subtitle .lbl { flex: 1; min-width: 0; }
  .sidebar .nav-subtitle .chev {
    flex-shrink: 0;
    width: 11px;
    font-size: 9px;
    color: var(--fg-dim);
    transition: transform 0.16s ease;
  }
  .sidebar .nav-group-item.expanded > .nav-subtitle .chev { transform: rotate(90deg); }
  .sidebar .nav-group-item:not(.expanded) > .nav-list { display: none; }

  /* 嵌套层级用一条淡淡的左引导线 */
  .sidebar .nav-list .nav-list {
    margin-left: 15px;
    border-left: 1px solid var(--border);
  }
</style>
