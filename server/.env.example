# 默认知识库 slug（当 URL 没有 /kb/<slug>/ 前缀时回退到这个 KB）
# DEFAULT_KB_SLUG=ai-ml-interview

# 外部静态挂载点（让 Docsify 渲染 KB 目录树之外的 markdown / 资源）
# 跨盘 junction 会触发 Starlette StaticFiles 的 ValueError，必须用独立 mount。
# 格式: JSON 对象，key 为 URL 前缀，value 为绝对文件系统路径。
# 单引号包裹整体，内部用双引号。Windows 路径推荐用正斜杠避免转义。
# 保留前缀（kb / api / server / knowledge_bases / _trash / _backup / docs）会被忽略。
# 示例: EXTERNAL_MOUNTS='{"external-reports":"F:/path/to/folder","notes":"D:/other"}'
# EXTERNAL_MOUNTS=

# ──────────────────────────────────────────────────
# 注：以下运行时设置都已经搬到 server/.settings.json，通过设置页
# (/docs/tools/settings.html) 管理，不需要写在 .env：
#   - AI backend (claude_cli / openai_api)
#   - Claude CLI 路径
#   - OpenAI API key / base URL / 模型列表
#   - ACCESS_PASSWORD（自动 scrypt 哈希）
